<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- ── Buildings with existing <comps> ─────────────────────────────── -->
  <Operation Class="PatchOperationAdd">
    <success>Always</success>
    <xpath>Defs/ThingDef[category="Building" and comps and not(comps/li[@Class="RimClaim.CompProperties_Ownership"])]/comps</xpath>
    <value>
      <li Class="RimClaim.CompProperties_Ownership" />
    </value>
  </Operation>

  <!-- ── Buildings without <comps> ───────────────────────────────────── -->
  <Operation Class="PatchOperationAdd">
    <success>Always</success>
    <xpath>Defs/ThingDef[category="Building" and not(comps)]</xpath>
    <value>
      <comps>
        <li Class="RimClaim.CompProperties_Ownership" />
      </comps>
    </value>
  </Operation>

  <!-- ── Items with existing <comps> ─────────────────────────────────── -->
  <Operation Class="PatchOperationAdd">
    <success>Always</success>
    <xpath>Defs/ThingDef[category="Item" and comps and not(comps/li[@Class="RimClaim.CompProperties_Ownership"])]/comps</xpath>
    <value>
      <li Class="RimClaim.CompProperties_Ownership" />
    </value>
  </Operation>

  <!-- ── Items without <comps> ───────────────────────────────────────── -->
  <Operation Class="PatchOperationAdd">
    <success>Always</success>
    <xpath>Defs/ThingDef[category="Item" and not(comps)]</xpath>
    <value>
      <comps>
        <li Class="RimClaim.CompProperties_Ownership" />
      </comps>
    </value>
  </Operation>

</Patch>
